BiocManager::install("Rsamtools")
library(Rsamtools)

samples <- c(
  "RA1",
  "RA2",
  "RA3",
  "RA4",
  "RA5",
  "RA6",
  "RA7",
  "RA8")

lapply(samples, function(s) {
  sortBam(
    file = paste0(s, ".BAM"),
    destination = paste0(s, ".sorted"))})

lapply(samples, function(s) {
  indexBam(
    file = paste0(s, ".sorted.bam"))})
bam_files <- c(
  "RA1.sorted.bam",
  "RA2.sorted.bam",
  "RA3.sorted.bam",
  "RA4.sorted.bam",
  "RA5.sorted.bam",
  "RA6.sorted.bam",
  "RA7.sorted.bam",
  "RA8.sorted.bam")

count_matrix <- featureCounts(
  files = bam_files,
  annot.ext = "genomic.gtf",
  isPairedEnd = TRUE,
  isGTFAnnotationFile = TRUE,
  GTF.attrType = "gene_id",
  useMetaFeatures = TRUE)
counts <- count_matrix$counts

dim(counts)

colnames(counts) <- c(
  "RA1_sorted",
  "RA2_sorted",
  "RA3_sorted",
  "RA4_sorted",
  "RA5_sorted",
  "RA6_sorted",
  "RA7_sorted",
  "RA8_sorted")

head(counts)
BiocManager::install("DESeq2")
BiocManager::install("EnhancedVolcano")

library(DESeq2)
library(EnhancedVolcano)

treatment <- c(
  "Normal", "Normal", "Normal", "Normal",
  "RA", "RA", "RA", "RA")

treatment_table <- data.frame(treatment)

rownames(treatment_table) <- colnames(counts)

treatment_table

dds <- DESeqDataSetFromMatrix(
  countData = counts,
  colData = treatment_table,
  design = ~ treatment)

dds <- DESeq(dds)

resultaten <- results(dds)

write.csv(
  as.data.frame(resultaten),
  "DESeq2_resultaten.csv")

head(resultaten)

upregulated_genes <- sum(
  resultaten$padj < 0.05 &
    resultaten$log2FoldChange > 1,
  na.rm = TRUE)

downregulated_genes <- sum(
  resultaten$padj < 0.05 &
    resultaten$log2FoldChange < -1,
  na.rm = TRUE)

upregulated_genes
downregulated_genes


resultaten_gesorteerd <- resultaten[
  order(resultaten$padj),]

head(resultaten_gesorteerd, 20)

EnhancedVolcano(
  resultaten,
  lab = rownames(resultaten),
  selectLab = c(
    "CXCL8",
    "MMP9",
    "CCL2",
    "BAX"
  ),
  x = "log2FoldChange",
  y = "padj",
  pCutoff = 0.05,
  FCcutoff = 1,
  xlim = c(-12, 12),
  drawConnectors = TRUE,
  widthConnectors = 0.5,
  colConnectors = "grey50",
  title = "Differentiële expressie RA vs Normal",
  subtitle = "DESeq2 analyse van synoviumbiopten",
  legendLabels = c(
    "NS",
    "Log2FC",
    "p-waarde",
    "beide"),
  colAlpha = 0.6)

