BiocManager::install("clusterProfiler")
BiocManager::install("org.Hs.eg.db")
BiocManager::install("enrichplot")

library(clusterProfiler)
library(org.Hs.eg.db)
library(enrichplot)

sig_genes <- resultaten[
  !is.na(resultaten$padj) &
    resultaten$padj < 0.05,]

gene_symbols <- rownames(sig_genes)

head(gene_symbols)

entrez <- bitr(
  gene_symbols,
  fromType = "SYMBOL",
  toType = "ENTREZID",
  OrgDb = org.Hs.eg.db)

head(entrez)

kegg <- enrichKEGG(
  gene = entrez$ENTREZID,
  organism = "hsa",
  pvalueCutoff = 0.05)

head(kegg)

dotplot(
  kegg,
  showCategory = 15)


kegg_df <- as.data.frame(kegg)

head(
  kegg_df[, c("Description", "p.adjust", "Count")],
  15)


go_bp <- enrichGO(
  gene = entrez$ENTREZID,
  OrgDb = org.Hs.eg.db,
  keyType = "ENTREZID",
  ont = "BP",
  pAdjustMethod = "BH",
  pvalueCutoff = 0.05,
  qvalueCutoff = 0.05,
  readable = TRUE)

head(as.data.frame(go_bp))

go_df <- as.data.frame(go_bp)

head(
  go_df[order(go_df$p.adjust), ],
  20)

barplot(
  go_bp,
  showCategory = 15)

dotplot(
  go_bp,
  showCategory = 15)

write.csv(
  go_df,
  "GO_BP_resultaten.csv",
  row.names = FALSE)

