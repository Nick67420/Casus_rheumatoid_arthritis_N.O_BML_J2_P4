up_genes <- rownames(
  resultaten[
    !is.na(resultaten$padj) &
      !is.na(resultaten$log2FoldChange) &
      resultaten$padj < 0.05 &
      resultaten$log2FoldChange > 1, ])


down_genes <- rownames(
  resultaten[
    !is.na(resultaten$padj) &
      !is.na(resultaten$log2FoldChange) &
      resultaten$padj < 0.05 & 
      resultaten$log2FoldChange < -1,])

length(up_genes)
length(down_genes)
